# Copie para `.env` na pasta `backend` e ajuste (o ficheiro `.env` não deve ser commitado).
# No Windows pode definir estas variáveis na sessão do PowerShell antes de correr Maven,
# ou usar uma ferramenta que carregue `.env`.
#
# Repositório público: antes de hospedar qualquer ambiente na internet,
# obrigatoriamente mude JWT_SECRET e as credenciais da base de dados.

# Base de dados (valores iguais ao docker-compose.yml local por defeito)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/jobflow
SPRING_DATASOURCE_USERNAME=jobflow
SPRING_DATASOURCE_PASSWORD=jobflow

# JWT — gere um valor forte, ex.: openssl rand -base64 48
JWT_SECRET=gere_um_segredo_longo_so_seu_sem_commitar_no_git
JOBFLOW_JWT_ISSUER=jobflow
JOBFLOW_JWT_TTL_MINUTES=60

# Opcional — utilizador seeded em desenvolvimento (DevUserDataLoader)
JOBFLOW_DEV_SEED_ADMIN=true
JOBFLOW_DEV_ADMIN_EMAIL=admin@jobflow.com
JOBFLOW_DEV_ADMIN_PASSWORD=admin
JOBFLOW_DEV_RESET_ADMIN_PASSWORD=true
